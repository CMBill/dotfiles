{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "keybinds": {
    "messages_previous": "ctrl+up",
    "messages_next": "ctrl+down",
    "messages_last_user": "ctrl+u"
  },
  "plugin": [
    "opencode-provider-balance@latest",
    [
      "opencode-visual-cache@latest",
      {
        "enabled": true
      }
    ]
  ],
  "scroll_acceleration": {
    "enabled": true
  }
}